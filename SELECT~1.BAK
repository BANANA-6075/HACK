//program to implement selection sort

#include<iostream.h>
#include<conio.h>
void selection_sort(int [],int);
void main()
{
clrscr();
int a[50],n;
cout<<"enter the size of the array"<<endl;
cin>>n;
cout<<"enter the elements"<<endl;
for(int i=0;i<n;i++)
cin>>a[i];
selection_sort(a,n);
cout<<"the sorted array is"<<endl; for(i=0;i<n;i++)
cout<<a[i]<<" "<<endl;
getch();
}

void selection_sort(int a[],int n)
{
int min,temp,j;
for(int i=0;i<n-1;i++)
 {
 min=i;
  for(j=i+1;j<n;j++)
  {
   if(a[j]<a[min])
{
min=j;
  }
 }
temp=a[i];
a[i]=a[min];
a[min]=temp;
}
}