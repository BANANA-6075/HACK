//8. Program to implement quick sort

#include<iostream.h>
#include<conio.h>
void quicksort(int a[],int,int);
void main()
{
int ar[30],n;
cout<<"enter the size of the array"<<endl;
cin>>n;
cout<<"enter the elements"<<endl;
for(int i=0;i<n;i++)
cin>>ar[i];
quicksort(ar,0,n-1);
cout<<"the sorted array is"<<endl;
for(i=0;i<n;i++)
cout<<ar[i]<<" "<<endl;
getch();
}
void quicksort(int x[],int lb,int ub)
 {
 int left, right, mid, temp;
 if(ub>lb)
  {
  left=lb;
  right=ub;
  mid=x[lb];
 while(left<right)
  {
   while(x[left]<=mid)
   left++;
   while(x[right]>mid)
   right--;
   if(left>right)
   break;
  temp=x[left];
  x[left]=x[right];
  x[right]=temp;
  }
x[lb]=x[right];
x[right]=mid;
quicksort(x, lb, right);
quicksort(x, left,ub);
 }
}